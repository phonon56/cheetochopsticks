<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Color palette — verified WCAG 2.1 AA / AAA on --bg #0c1220
         Contrast ratios (minimum text 4.5:1 AA, 7:1 AAA):
           text    #ede8dc → 15.3  AAA
           muted   #96adc4 →  8.1  AAA
           quiet   #8ca3b8 →  7.2  AAA  (was #506070, 2.9 — FAIL)
           gold    #c8a84b →  8.2  AAA
           gold-lt #fde68a → 15.0  AAA
           red     #fca5a5 →  9.9  AAA  (was #f87171, 6.8 AA)
           green   #4ade80 → 10.7  AAA
           blue    #60a5fa →  7.4  AAA
           amber   #fbbf24 → 11.2  AAA                                  */
      --bg:         #0c1220;
      --surface:    #141e2e;
      --surface2:   #1c2a3e;
      --surface3:   #233045;
      --border:     rgba(255,255,255,.14);
      --border-hi:  rgba(255,255,255,.28);
      --gold:       #c8a84b;
      --gold-dim:   rgba(200,168,75,.22);
      --gold-faint: rgba(200,168,75,.09);
      --gold-lt:    #fde68a;
      --text:       #ede8dc;
      --muted:      #96adc4;
      --quiet:      #8ca3b8;
      --mono:       'IBM Plex Mono', monospace;
      --sans:       'IBM Plex Sans', sans-serif;
      --serif:      'Playfair Display', Georgia, serif;
      --red:        #fca5a5;
      --red-dim:    rgba(252,165,165,.16);
      --green:      #4ade80;
      --green-dim:  rgba(74,222,128,.14);
      --blue:       #60a5fa;
      --blue-dim:   rgba(96,165,250,.14);
      --amber:      #fbbf24;
      --amber-dim:  rgba(251,191,36,.16);
    }

    html { scroll-behavior: smooth; }

    /* ── Skip link (ADA) ────────────────────────────────────── */
    .skip-link {
      position: absolute;
      top: -100px;
      left: 16px;
      background: var(--gold);
      color: #0c1220;
      font-family: var(--mono);
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .08em;
      padding: 10px 18px;
      border-radius: 3px;
      text-decoration: none;
      z-index: 9999;
      transition: top .2s;
    }
    .skip-link:focus { top: 16px; }

    /* ── Focus visible — universal gold ring ─────────────────────── */
    *:focus { outline: none; }
    *:focus-visible {
      outline: 3px solid var(--gold);
      outline-offset: 3px;
      border-radius: 2px;
    }

    /* ── Serif subheadline ───────────────────────────────────────── */
    .section-sub {
      font-family: var(--sans);
      font-style: normal;
      font-weight: 400;
      font-size: 1.05rem;
      color: var(--muted);
      line-height: 1.6;
      margin-top: 4px;
      margin-bottom: 28px;
      max-width: 560px;
    }

    @media (prefers-reduced-motion: reduce) {
      .ticker-track { animation: none; }
      * { transition-duration: 0.01ms !important; }
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 18px;
      line-height: 1.7;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    .container { max-width: 900px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

    /* ── NAV ─────────────────────────────────────────────────────── */
    .nav {
      border-bottom: 1px solid var(--border);
      padding: 14px 0;
      position: sticky;
      top: 0;
      background: rgba(10,15,26,.94);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      z-index: 200;
    }
    .nav-inner {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .nav-logo {
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 1px;
      margin-right: 32px;
      flex-shrink: 0;
    }
    .nav-logo-img {
      height: 42px;
      width: auto;
      display: block;
    }
    .nav-logo:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 4px;
      border-radius: 2px;
    }
    /* Legacy text-logo styles kept for any other surfaces that reference them */
    .nav-logo-word {
      font-family: var(--sans);
      font-weight: 600;
      font-size: .95rem;
      letter-spacing: -.01em;
      color: var(--text);
    }
    .nav-logo-dot { color: var(--gold); font-size: .95rem; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
      flex: 1;
    }
    .nav-link {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 3px;
      border: 1px solid transparent;
      transition: all .18s;
      white-space: nowrap;
    }
    .nav-link:hover { color: var(--text); background: rgba(255,255,255,.04); }
    .nav-link.you-link {
      color: var(--gold);
      border-color: var(--gold-dim);
      background: var(--gold-faint);
    }
    .nav-link.you-link:hover { background: var(--gold-dim); }
    .nav-link.active {
      color: var(--text);
      border-color: var(--border-hi);
      background: rgba(255,255,255,.06);
      text-decoration: underline;
      text-decoration-color: var(--gold);
      text-underline-offset: 3px;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-left: auto;
      flex-shrink: 0;
    }
    .notif-btn {
      position: relative;
      background: none;
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 6px 10px;
      cursor: pointer;
      color: var(--muted);
      font-size: .78rem;
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--mono);
      letter-spacing: .06em;
      transition: all .18s;
    }
    .notif-btn:hover { color: var(--text); border-color: var(--border-hi); }
    .notif-count {
      background: var(--red);
      color: #0a0f1a;
      font-size: .78rem;
      font-weight: 700;
      border-radius: 10px;
      padding: 1px 5px;
      font-family: var(--mono);
      line-height: 1.4;
    }

    /* ── NOTIFICATIONS PANEL ─────────────────────────────────────── */
    .notif-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.4);
      z-index: 300;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s;
    }
    .notif-overlay.open { opacity: 1; pointer-events: all; }
    .notif-panel {
      position: fixed;
      top: 0; right: 0; bottom: 0;
      width: 360px;
      background: var(--surface);
      border-left: 1px solid var(--border-hi);
      z-index: 301;
      transform: translateX(100%);
      transition: transform .28s cubic-bezier(.32,.72,0,1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .notif-panel.open { transform: translateX(0); }
    .notif-panel-head {
      padding: 20px 20px 14px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .notif-panel-title {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--text);
    }
    .notif-close {
      background: none;
      border: 1px solid var(--border);
      border-radius: 3px;
      color: var(--muted);
      font-size: .78rem;
      padding: 4px 10px;
      cursor: pointer;
      font-family: var(--mono);
      transition: all .15s;
    }
    .notif-close:hover { color: var(--text); border-color: var(--border-hi); }
    .notif-filters {
      display: flex;
      gap: 6px;
      padding: 12px 20px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      flex-wrap: wrap;
    }
    .nf-btn {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 2px;
      background: none;
      color: var(--muted);
      cursor: pointer;
      transition: all .15s;
    }
    .nf-btn:hover { color: var(--text); border-color: var(--border-hi); }
    .nf-btn.active { background: var(--gold-dim); color: var(--gold); border-color: rgba(200,168,75,.3); }
    .notif-scroll { flex: 1; overflow-y: auto; padding: 8px 0; }
    .notif-group-label {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--quiet);
      padding: 10px 20px 4px;
    }
    .notif-item {
      padding: 12px 20px;
      display: flex;
      gap: 12px;
      align-items: flex-start;
      border-bottom: 1px solid var(--border);
      transition: background .15s;
      cursor: default;
    }
    .notif-item:hover { background: rgba(255,255,255,.02); }
    .notif-item.hidden { display: none; }
    .notif-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 5px;
    }
    .nd-red    { background: var(--red); }
    .nd-amber  { background: var(--amber); }
    .nd-blue   { background: var(--blue); }
    .nd-green  { background: var(--green); }
    .nd-gold   { background: var(--gold); }
    .nd-quiet  { background: var(--quiet); }
    .notif-body { flex: 1; }
    .notif-text {
      font-size: .85rem;
      color: var(--text);
      line-height: 1.55;
      margin-bottom: 3px;
    }
    .notif-text strong { color: var(--gold-lt); font-weight: 500; }
    .notif-meta {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .08em;
      color: var(--quiet);
      margin-bottom: 4px;
    }
    .notif-action {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid var(--gold-dim);
      padding-bottom: 1px;
      transition: border-color .15s;
    }
    .notif-action:hover { border-color: var(--gold); }

</style>
