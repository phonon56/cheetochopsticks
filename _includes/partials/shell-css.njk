<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Color palette — verified WCAG 2.1 AA / AAA on --bg #0c1220
         Contrast ratios (minimum text 4.5:1 AA, 7:1 AAA):
           text    #ede8dc → 15.3  AAA
           muted   #96adc4 →  8.1  AAA
           quiet   #8ca3b8 →  7.2  AAA  (was #506070, 2.9 — FAIL)
           gold    #c8a84b →  8.2  AAA
           gold-lt #fde68a → 15.0  AAA
           red     #fca5a5 →  9.9  AAA  (was #f87171, 6.8 AA)
           green   #4ade80 → 10.7  AAA
           blue    #60a5fa →  7.4  AAA
           amber   #fbbf24 → 11.2  AAA                                  */
      --cc-bg:         #0c1220;
      --cc-surface:    #141e2e;
      --cc-surface2:   #1c2a3e;
      --cc-surface3:   #233045;
      --cc-border:     rgba(255,255,255,.14);
      --cc-border-hi:  rgba(255,255,255,.28);
      --cc-gold:       #c8a84b;
      --cc-gold-dim:   rgba(200,168,75,.22);
      --cc-gold-faint: rgba(200,168,75,.09);
      --cc-gold-lt:    #fde68a;
      --cc-text:       #ede8dc;
      --cc-muted:      #96adc4;
      --cc-quiet:      #8ca3b8;
      --cc-mono:       'IBM Plex Mono', monospace;
      --cc-sans:       'IBM Plex Sans', sans-serif;
      --cc-serif:      'Playfair Display', Georgia, serif;
      --cc-red:        #fca5a5;
      --cc-red-dim:    rgba(252,165,165,.16);
      --cc-green:      #4ade80;
      --cc-green-dim:  rgba(74,222,128,.14);
      --cc-blue:       #60a5fa;
      --cc-blue-dim:   rgba(96,165,250,.14);
      --cc-amber:      #fbbf24;
      --cc-amber-dim:  rgba(251,191,36,.16);
    }

    html { scroll-behavior: smooth; }

    /* ── Skip link (ADA) ────────────────────────────────────── */
    .skip-link {
      position: absolute;
      top: -100px;
      left: 16px;
      background: var(--cc-gold);
      color: #0c1220;
      font-family: var(--cc-mono);
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .08em;
      padding: 10px 18px;
      border-radius: 3px;
      text-decoration: none;
      z-index: 9999;
      transition: top .2s;
    }
    .skip-link:focus { top: 16px; }

    /* ── Focus visible — universal gold ring ─────────────────────── */
    *:focus { outline: none; }
    *:focus-visible {
      outline: 3px solid var(--cc-gold);
      outline-offset: 3px;
      border-radius: 2px;
    }

    /* ── Serif subheadline ───────────────────────────────────────── */
    .section-sub {
      font-family: var(--cc-sans);
      font-style: normal;
      font-weight: 400;
      font-size: 1.05rem;
      color: var(--cc-muted);
      line-height: 1.6;
      margin-top: 4px;
      margin-bottom: 28px;
      max-width: 560px;
    }

    @media (prefers-reduced-motion: reduce) {
      .ticker-track { animation: none; }
      * { transition-duration: 0.01ms !important; }
    }

    body {
      background: var(--cc-bg);
      color: var(--cc-text);
      font-family: var(--cc-sans);
      font-size: 18px;
      line-height: 1.7;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    .container { max-width: 900px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

    /* ── NAV ─────────────────────────────────────────────────────── */
    .nav {
      border-bottom: 1px solid var(--cc-border);
      padding: 14px 0;
      position: sticky;
      top: 0;
      background: rgba(10,15,26,.94);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      z-index: 200;
    }
    .nav-inner {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .nav-logo {
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 1px;
      margin-right: 32px;
      flex-shrink: 0;
    }
    .nav-logo-img {
      height: 42px;
      width: auto;
      display: block;
    }
    .nav-logo:focus-visible {
      outline: 2px solid var(--cc-gold);
      outline-offset: 4px;
      border-radius: 2px;
    }
    /* Legacy text-logo styles kept for any other surfaces that reference them */
    .nav-logo-word {
      font-family: var(--cc-sans);
      font-weight: 600;
      font-size: .95rem;
      letter-spacing: -.01em;
      color: var(--cc-text);
    }
    .nav-logo-dot { color: var(--cc-gold); font-size: .95rem; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
      flex: 1;
    }
    .nav-link {
      font-family: var(--cc-mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--cc-muted);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 3px;
      border: 1px solid transparent;
      transition: all .18s;
      white-space: nowrap;
    }
    .nav-link:hover { color: var(--cc-text); background: rgba(255,255,255,.04); }
    .nav-link.you-link {
      color: var(--cc-gold);
      border-color: var(--cc-gold-dim);
      background: var(--cc-gold-faint);
    }
    .nav-link.you-link:hover { background: var(--cc-gold-dim); }
    .nav-link.active {
      color: var(--cc-text);
      border-color: var(--cc-border-hi);
      background: rgba(255,255,255,.06);
      text-decoration: underline;
      text-decoration-color: var(--cc-gold);
      text-underline-offset: 3px;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-left: auto;
      flex-shrink: 0;
    }
    .notif-btn {
      position: relative;
      background: none;
      border: 1px solid var(--cc-border);
      border-radius: 4px;
      padding: 6px 10px;
      cursor: pointer;
      color: var(--cc-muted);
      font-size: .78rem;
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--cc-mono);
      letter-spacing: .06em;
      transition: all .18s;
    }
    .notif-btn:hover { color: var(--cc-text); border-color: var(--cc-border-hi); }

    /* ── NAV SEARCH (top-nav disclosure pattern) ───────────────────
       Toggle button sits next to Subscribe / Alerts; the dropdown
       panel is positioned absolutely below the nav and animates in
       only when expanded. JS in nav-scripts.njk handles open/close,
       focus management, Escape, click-outside, and lazy fetch. */
    .nav-search-toggle {
      background: none;
      border: 1px solid var(--cc-border);
      border-radius: 4px;
      padding: 6px 12px;
      cursor: pointer;
      color: var(--cc-muted);
      font-size: .78rem;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--cc-mono);
      letter-spacing: .06em;
      transition: color .18s, border-color .18s;
      margin-right: 8px;
      min-height: 32px;
    }
    .nav-search-toggle:hover { color: var(--cc-text); border-color: var(--cc-border-hi); }
    .nav-search-toggle:focus-visible {
      outline: 3px solid var(--cc-gold);
      outline-offset: 2px;
    }
    .nav-search-toggle[aria-expanded="true"] {
      color: var(--cc-bg);
      background: var(--cc-gold);
      border-color: var(--cc-gold);
    }
    .nav-search-toggle__icon {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }
    .nav-search-toggle__label {
      letter-spacing: .08em;
      text-transform: uppercase;
      font-weight: 600;
    }
    @media (max-width: 600px) {
      .nav-search-toggle { padding: 6px 8px; }
      .nav-search-toggle__label { display: none; }
    }

    /* Dropdown panel — full-width below nav, dark surface that matches
       the notification panel treatment for visual consistency. */
    .nav-search-panel {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 35;
      background: var(--cc-surface);
      border-bottom: 1px solid var(--cc-border-hi);
      box-shadow: 0 6px 20px rgba(0,0,0,.35);
    }
    .nav-search-panel[hidden] { display: none; }
    .nav-search-panel__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px 24px 24px;
    }
    .nav-search-panel__chips {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
    .nav-search-panel__chip {
      background: transparent;
      color: var(--cc-muted);
      border: 1px solid var(--cc-border-hi);
      border-radius: 999px;
      padding: 5px 14px;
      font-family: var(--cc-mono);
      font-size: .76rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      font-weight: 600;
      cursor: pointer;
      transition: color .15s, border-color .15s, background .15s;
    }
    .nav-search-panel__chip:hover { color: var(--cc-text); border-color: var(--cc-gold); }
    .nav-search-panel__chip:focus-visible {
      outline: 3px solid var(--cc-gold);
      outline-offset: 2px;
    }
    .nav-search-panel__chip[aria-pressed="true"] {
      color: var(--cc-bg);
      background: var(--cc-gold);
      border-color: var(--cc-gold);
    }
    .nav-search-panel__form {
      display: flex;
      gap: 8px;
      align-items: stretch;
    }
    .nav-search-panel__input {
      flex: 1;
      min-width: 0;
      background: var(--cc-bg);
      color: var(--cc-text);
      border: 1px solid var(--cc-border-hi);
      border-radius: 4px;
      padding: 10px 14px;
      font-family: var(--cc-sans);
      font-size: 1rem;
      line-height: 1.4;
      min-height: 44px;
    }
    .nav-search-panel__input::placeholder { color: var(--cc-quiet); }
    .nav-search-panel__input:focus-visible {
      outline: 3px solid var(--cc-gold);
      outline-offset: 1px;
      border-color: var(--cc-gold);
    }
    .nav-search-panel__submit,
    .nav-search-panel__close {
      background: var(--cc-gold);
      color: var(--cc-bg);
      border: 1px solid var(--cc-gold);
      border-radius: 4px;
      padding: 0 16px;
      font-family: var(--cc-mono);
      font-size: 1rem;
      cursor: pointer;
      min-height: 44px;
      min-width: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .nav-search-panel__close {
      background: transparent;
      color: var(--cc-muted);
      border-color: var(--cc-border-hi);
    }
    .nav-search-panel__submit:hover,
    .nav-search-panel__close:hover { background: var(--cc-gold-lt); border-color: var(--cc-gold-lt); color: var(--cc-bg); }
    .nav-search-panel__submit:focus-visible,
    .nav-search-panel__close:focus-visible {
      outline: 3px solid var(--cc-gold);
      outline-offset: 2px;
    }
    .nav-search-panel__status {
      font-family: var(--cc-mono);
      font-size: .76rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--cc-muted);
      margin: 12px 0 8px;
      min-height: 1.4em;
    }
    .nav-search-panel__results {
      list-style: none;
      margin: 0;
      padding: 0;
      max-height: 60vh;
      overflow-y: auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .nav-search-panel__item {
      display: block;
      padding: 12px 16px;
      background: var(--cc-bg);
      border: 1px solid var(--cc-border);
      border-radius: 4px;
      text-decoration: none;
      color: var(--cc-text);
      border-left-width: 4px;
      transition: border-color .15s, background .15s;
    }
    .nav-search-panel__item:hover { border-color: var(--cc-border-hi); background: var(--cc-surface); }
    .nav-search-panel__item:focus-visible {
      outline: 3px solid var(--cc-gold);
      outline-offset: 2px;
    }
    .nav-search-panel__item--local    { border-left-color: var(--cc-gold); }
    .nav-search-panel__item--state    { border-left-color: var(--cc-blue); }
    .nav-search-panel__item--national { border-left-color: var(--cc-green); }
    .nav-search-panel__item-scope {
      font-family: var(--cc-mono);
      font-size: .7rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--cc-muted);
      margin: 0 0 3px;
    }
    .nav-search-panel__item--local .nav-search-panel__item-scope    { color: var(--cc-gold); }
    .nav-search-panel__item--state .nav-search-panel__item-scope    { color: var(--cc-blue); }
    .nav-search-panel__item--national .nav-search-panel__item-scope { color: var(--cc-green); }
    .nav-search-panel__item-title {
      font-weight: 600;
      font-size: .95rem;
      color: var(--cc-text);
      line-height: 1.35;
      margin: 0 0 3px;
    }
    .nav-search-panel__item-desc {
      font-size: .82rem;
      color: var(--cc-muted);
      line-height: 1.45;
      margin: 0;
    }
    .nav-search-panel__item mark {
      background: rgba(200,168,75,.28);
      color: var(--cc-text);
      padding: 1px 3px;
      border-radius: 2px;
    }
    .nav-search-panel__empty {
      font-size: .9rem;
      color: var(--cc-muted);
      padding: 12px 0;
      margin: 0;
    }
    @media (max-width: 700px) {
      .nav-search-panel__inner { padding: 16px 16px 18px; }
      .nav-search-panel__chips { gap: 4px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .nav-search-toggle,
      .nav-search-panel__chip,
      .nav-search-panel__item { transition: none; }
    }
    .notif-count {
      background: var(--cc-red);
      color: #0a0f1a;
      font-size: .78rem;
      font-weight: 700;
      border-radius: 10px;
      padding: 1px 5px;
      font-family: var(--cc-mono);
      line-height: 1.4;
    }

    /* ── NOTIFICATIONS PANEL ─────────────────────────────────────── */
    .notif-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.4);
      z-index: 300;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s;
    }
    .notif-overlay.open { opacity: 1; pointer-events: all; }
    .notif-panel {
      position: fixed;
      top: 0; right: 0; bottom: 0;
      width: 360px;
      background: var(--cc-surface);
      border-left: 1px solid var(--cc-border-hi);
      z-index: 301;
      transform: translateX(100%);
      transition: transform .28s cubic-bezier(.32,.72,0,1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .notif-panel.open { transform: translateX(0); }
    .notif-panel-head {
      padding: 20px 20px 14px;
      border-bottom: 1px solid var(--cc-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .notif-panel-title {
      font-family: var(--cc-mono);
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--cc-text);
    }
    .notif-close {
      background: none;
      border: 1px solid var(--cc-border);
      border-radius: 3px;
      color: var(--cc-muted);
      font-size: .78rem;
      padding: 4px 10px;
      cursor: pointer;
      font-family: var(--cc-mono);
      transition: all .15s;
    }
    .notif-close:hover { color: var(--cc-text); border-color: var(--cc-border-hi); }
    .notif-filters {
      display: flex;
      gap: 6px;
      padding: 12px 20px;
      border-bottom: 1px solid var(--cc-border);
      flex-shrink: 0;
      flex-wrap: wrap;
    }
    .nf-btn {
      font-family: var(--cc-mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 4px 10px;
      border: 1px solid var(--cc-border);
      border-radius: 2px;
      background: none;
      color: var(--cc-muted);
      cursor: pointer;
      transition: all .15s;
    }
    .nf-btn:hover { color: var(--cc-text); border-color: var(--cc-border-hi); }
    .nf-btn.active { background: var(--cc-gold-dim); color: var(--cc-gold); border-color: rgba(200,168,75,.3); }
    .notif-scroll { flex: 1; overflow-y: auto; padding: 8px 0; }
    .notif-group-label {
      font-family: var(--cc-mono);
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--cc-quiet);
      padding: 10px 20px 4px;
    }
    .notif-item {
      padding: 12px 20px;
      display: flex;
      gap: 12px;
      align-items: flex-start;
      border-bottom: 1px solid var(--cc-border);
      transition: background .15s;
      cursor: default;
    }
    .notif-item:hover { background: rgba(255,255,255,.02); }
    .notif-item.hidden { display: none; }
    .notif-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 5px;
    }
    .nd-red    { background: var(--cc-red); }
    .nd-amber  { background: var(--cc-amber); }
    .nd-blue   { background: var(--cc-blue); }
    .nd-green  { background: var(--cc-green); }
    .nd-gold   { background: var(--cc-gold); }
    .nd-quiet  { background: var(--cc-quiet); }
    .notif-body { flex: 1; }
    .notif-text {
      font-size: .85rem;
      color: var(--cc-text);
      line-height: 1.55;
      margin-bottom: 3px;
    }
    .notif-text strong { color: var(--cc-gold-lt); font-weight: 500; }
    .notif-meta {
      font-family: var(--cc-mono);
      font-size: .78rem;
      letter-spacing: .08em;
      color: var(--cc-quiet);
      margin-bottom: 4px;
    }
    .notif-action {
      font-family: var(--cc-mono);
      font-size: .78rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--cc-gold);
      text-decoration: none;
      border-bottom: 1px solid var(--cc-gold-dim);
      padding-bottom: 1px;
      transition: border-color .15s;
    }
    .notif-action:hover { border-color: var(--cc-gold); }

    /* ── FOOTER ─────────────────────────────────────────────────── */
    /* footer.cc-footer (specificity 0,1,1) so page-level bare `footer { … }`
       rules can't overpaint it on pages with their own theme. */
    footer.cc-footer {
      border-top: 1px solid var(--cc-border);
      padding: 32px 0 36px;
      margin-top: 56px;
      background: var(--cc-bg);
      color: var(--cc-text);
      position: relative;
      z-index: 1;
    }
    .cc-footer .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .cc-footer-line {
      font-family: var(--cc-mono);
      font-size: .78rem;
      letter-spacing: .04em;
      line-height: 1.9;
      color: var(--cc-muted);
      text-align: center;
    }
    .cc-footer-line a {
      color: var(--cc-muted);
      text-decoration: underline;
      text-decoration-color: rgba(150, 173, 196, .35);
      text-underline-offset: 3px;
      transition: color .15s, text-decoration-color .15s;
    }
    .cc-footer-line a:hover,
    .cc-footer-line a:focus-visible {
      color: var(--cc-gold);
      text-decoration-color: var(--cc-gold);
    }
    .cc-footer-ext {
      display: inline-block;
      font-size: .7em;
      transform: translateY(-1px);
      margin-left: 2px;
      opacity: .7;
    }
    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0,0,0,0);
      white-space: nowrap; border: 0;
    }

    /* ── MARKDOWN CONTENT (rendered .md docs) ───────────────────── */
    .markdown-content {
      max-width: 760px;
      margin: 0 auto;
      padding: 48px 24px 80px;
      color: var(--cc-text);
      font-family: var(--cc-sans);
      font-size: 1rem;
      line-height: 1.7;
    }
    .markdown-header {
      border-bottom: 1px solid var(--cc-border);
      padding-bottom: 24px;
      margin-bottom: 32px;
    }
    .markdown-content > .markdown-header h1,
    .markdown-content h1 {
      font-family: var(--cc-serif);
      font-size: clamp(1.8rem, 4vw, 2.4rem);
      font-weight: 700;
      line-height: 1.2;
      color: var(--cc-text);
      margin: 0 0 8px;
    }
    .markdown-subtitle {
      font-style: italic;
      color: var(--cc-muted);
      font-size: 1.05rem;
      margin: 0;
    }
    .markdown-content h2 {
      font-family: var(--cc-serif);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--cc-text);
      margin: 48px 0 12px;
      padding-top: 12px;
      border-top: 1px solid var(--cc-border);
    }
    .markdown-content h3 {
      font-family: var(--cc-serif);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--cc-gold-lt);
      margin: 32px 0 8px;
    }
    .markdown-content h4 {
      font-family: var(--cc-mono);
      font-size: .85rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--cc-muted);
      margin: 24px 0 6px;
    }
