<script>
/* ── Site nav + notifications panel scripts ──────────────────────────
   Wrapped in an IIFE so locals never leak. The functions onclick handlers
   call (openNotif, closeNotif, filterNotif) are explicitly attached to
   `window` so a page's own scripts can't shadow them, and each function
   is defensive about the DOM possibly being absent on a page that opted
   out of the layout. */
(function () {
  function $(id) { return document.getElementById(id); }

  var lastFocus;

  function openNotif() {
    var overlay = $('notif-overlay');
    var panel   = $('notif-panel');
    var btn     = document.querySelector('.notif-btn');
    if (!overlay || !panel || !btn) return;
    lastFocus = document.activeElement;
    overlay.classList.add('open');
    overlay.removeAttribute('aria-hidden');
    panel.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    setTimeout(function () { panel.focus(); }, 50);
  }

  function closeNotif() {
    var overlay = $('notif-overlay');
    var panel   = $('notif-panel');
    var btn     = document.querySelector('.notif-btn');
    if (!overlay || !panel || !btn) return;
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    panel.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
  }

  function filterNotif(tier, btn) {
    document.querySelectorAll('.nf-btn').forEach(function (b) {
      b.classList.remove('active');
      b.removeAttribute('aria-pressed');
    });
    if (btn) {
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
    }
    document.querySelectorAll('.notif-item').forEach(function (item) {
      if (tier === 'all') {
        item.classList.remove('hidden');
        item.removeAttribute('aria-hidden');
      } else {
        var hide = item.dataset.tier !== tier;
        item.classList.toggle('hidden', hide);
        if (hide) item.setAttribute('aria-hidden', 'true');
        else item.removeAttribute('aria-hidden');
      }
    });
    document.querySelectorAll('.notif-group-label').forEach(function (label) {
      label.style.display = tier === 'all' ? '' : 'none';
    });
  }

  /* Escape closes the panel; Tab stays inside it while it's open. */
  document.addEventListener('keydown', function (e) {
    var panel = $('notif-panel');
    if (!panel) return;
    if (e.key === 'Escape') { closeNotif(); return; }
    if (e.key === 'Tab' && panel.classList.contains('open')) {
      var focusable = panel.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])');
      if (!focusable.length) return;
      var first = focusable[0], last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
  });

  /* Active nav link on scroll — only runs when the index has the matching anchors. */
  var navLinks = document.querySelectorAll('.nav-link');
  var sections = ['you', 'dashboards', 'people', 'events'];
  if (typeof IntersectionObserver === 'function' && navLinks.length) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var id = entry.target.id;
          navLinks.forEach(function (l) {
            var href = l.getAttribute('href') || '';
            var active = href === '#' + id || href === '/#' + id;
            l.classList.toggle('active', active);
            if (active) l.setAttribute('aria-current', 'true');
            else l.removeAttribute('aria-current');
          });
        }
      });
    }, { rootMargin: '-40% 0px -50% 0px' });
    sections.forEach(function (id) {
      var el = $(id);
      if (el) observer.observe(el);
    });
  }

  /* Expose the click-target functions globally so inline onclick handlers
     (and any page that needs them) can always reach them by name. */
  window.openNotif   = openNotif;
  window.closeNotif  = closeNotif;
  window.filterNotif = filterNotif;

  /* ─── Nav search (disclosure pattern + lazy fetch + filter) ───────
     The toggle button uses aria-expanded to advertise state; opening
     it un-hides the panel, moves focus to the input, attaches Escape
     and click-outside handlers, and fetches /search-index.json on
     first open (cached for the rest of the session). All search
     scoring matches the homepage block so results rank identically. */
  var nsToggle   = $('nav-search-toggle');
  var nsPanel    = $('nav-search-panel');
  var nsForm     = $('nav-search-form');
  var nsInput    = $('nav-search-input');
  var nsClose    = $('nav-search-close');
  var nsStatus   = $('nav-search-status');
  var nsResults  = $('nav-search-results');
  var nsEmpty    = $('nav-search-empty');
  var nsChips    = document.querySelectorAll('.nav-search-panel__chip');

  if (nsToggle && nsPanel && nsForm && nsInput) {
    var nsIndex = null;
    var nsTier  = 'all';
    var nsDebounce = null;

    function nsOpen() {
      nsPanel.hidden = false;
      nsToggle.setAttribute('aria-expanded', 'true');
      ensureIndex();
      /* Defer focus one tick so the panel is in the layout. */
      setTimeout(function(){ nsInput && nsInput.focus(); }, 0);
      document.addEventListener('keydown', nsOnKey);
      document.addEventListener('click', nsOnDocClick, true);
    }
    function nsClosePanel(returnFocus) {
      nsPanel.hidden = true;
      nsToggle.setAttribute('aria-expanded', 'false');
      document.removeEventListener('keydown', nsOnKey);
      document.removeEventListener('click', nsOnDocClick, true);
      if (returnFocus !== false) nsToggle.focus();
    }
    function nsOnKey(e) {
      if (e.key === 'Escape') { e.preventDefault(); nsClosePanel(true); }
    }
    function nsOnDocClick(e) {
      if (!nsPanel.contains(e.target) && e.target !== nsToggle && !nsToggle.contains(e.target)) {
        nsClosePanel(false);
      }
    }

    nsToggle.addEventListener('click', function() {
      var open = nsToggle.getAttribute('aria-expanded') === 'true';
      if (open) nsClosePanel(true); else nsOpen();
    });
    if (nsClose) nsClose.addEventListener('click', function() { nsClosePanel(true); });

    function ensureIndex() {
      if (nsIndex !== null) return Promise.resolve(nsIndex);
      if (nsStatus) nsStatus.textContent = 'Loading search index…';
      return fetch('/search-index.json', { headers: { 'Accept': 'application/json' } })
        .then(function(r){ if (!r.ok) throw new Error('failed'); return r.json(); })
        .then(function(data){ nsIndex = Array.isArray(data) ? data : []; if (nsStatus) nsStatus.textContent = ''; return nsIndex; })
        .catch(function(){ nsIndex = []; if (nsStatus) nsStatus.textContent = 'Search index failed to load — try refreshing.'; return nsIndex; });
    }

    var ZIP_RE    = /^\s*\d{5}(-\d{4})?\s*$/;
    var STREET_RE = /\b\d+\s+\w+.*\b(st|street|ave|avenue|blvd|boulevard|rd|road|dr|drive|ln|lane|way|ct|court|pl|place|hwy|highway|pkwy|parkway)\b/i;
    function nsLooksLikeAddress(q) { return ZIP_RE.test(q) || STREET_RE.test(q); }
    function nsEsc(s){
      return String(s).replace(/[&<>"']/g, function(c){
        return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
      });
    }
    function nsHighlight(text, terms){
      if (!terms.length) return nsEsc(text);
      var safe = nsEsc(text);
      var sorted = terms.slice().sort(function(a,b){ return b.length - a.length; });
      var pattern = sorted.map(function(t){ return t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }).join('|');
      var re = new RegExp('(' + pattern + ')', 'gi');
      return safe.replace(re, '<mark>$1</mark>');
    }
    function nsScore(item, terms){
      var pathStr = (item.path || '').toLowerCase();
      var hay = (item.title + ' ' + item.desc + ' ' + item.scope + ' ' + pathStr).toLowerCase();
      var s = 0;
      for (var i=0;i<terms.length;i++){
        var t = terms[i];
        if (item.title.toLowerCase().indexOf(t) !== -1) s += 5;
        if (item.scope.toLowerCase().indexOf(t) !== -1) s += 3;
        if (item.desc.toLowerCase().indexOf(t) !== -1)  s += 2;
        if (pathStr.indexOf(t) !== -1)                   s += 1;
        if (hay.indexOf(t) === -1) return -1;
      }
      return s;
    }
    function nsRender(items, terms){
      nsResults.innerHTML = '';
      if (!items.length) {
        if (nsStatus) nsStatus.textContent = '';
        if (nsEmpty)  nsEmpty.hidden = false;
        return;
      }
      if (nsEmpty) nsEmpty.hidden = true;
      if (nsStatus) nsStatus.textContent = items.length + ' result' + (items.length === 1 ? '' : 's');
      var frag = document.createDocumentFragment();
      items.forEach(function(it){
        var li = document.createElement('li');
        var a = document.createElement('a');
        a.className = 'nav-search-panel__item nav-search-panel__item--' + it.tier;
        a.href = it.url;
        a.innerHTML =
          '<p class="nav-search-panel__item-scope">' + nsEsc(it.scope) + '</p>' +
          '<p class="nav-search-panel__item-title">' + nsHighlight(it.title, terms) + '</p>' +
          (it.desc ? '<p class="nav-search-panel__item-desc">' + nsHighlight(it.desc, terms) + '</p>' : '');
        li.appendChild(a);
        frag.appendChild(li);
      });
      nsResults.appendChild(frag);
    }
    function nsRun(q) {
      q = (q || '').trim();
      if (!q) {
        nsResults.innerHTML = '';
        if (nsEmpty)  nsEmpty.hidden = true;
        if (nsStatus) nsStatus.textContent = '';
        return;
      }
      if (nsLooksLikeAddress(q)) {
        window.location.href = '/microsites/shared/cos-find-my-jurisdiction.html?q=' + encodeURIComponent(q);
        return;
      }
      ensureIndex().then(function(idx){
        var terms = q.toLowerCase().split(/\s+/).filter(Boolean);
        var pool  = (nsTier === 'all') ? idx : idx.filter(function(it){ return it.tier === nsTier; });
        var scored = [];
        for (var i=0;i<pool.length;i++) {
          var s = nsScore(pool[i], terms);
          if (s >= 0) scored.push({ s:s, it:pool[i] });
        }
        scored.sort(function(a,b){ return b.s - a.s; });
        nsRender(scored.slice(0, 30).map(function(x){ return x.it; }), terms);
      });
    }

    nsInput.addEventListener('input', function() {
      clearTimeout(nsDebounce);
      nsDebounce = setTimeout(function(){ nsRun(nsInput.value); }, 100);
    });
    nsForm.addEventListener('submit', function(e) {
      e.preventDefault();
      nsRun(nsInput.value);
    });
    nsChips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        nsTier = chip.dataset.tier;
        nsChips.forEach(function(c){ c.setAttribute('aria-pressed', c === chip ? 'true' : 'false'); });
        nsRun(nsInput.value);
      });
    });
  }
})();
</script>
