<!-- ═══════════════════════════════════════════════════════════════════
     NAV — sourced from a single partial; pages mark their active section
     by setting `activeNav` in front-matter (one of: orgchart, local,
     state, national). Legacy values (you, dashboards, people, events)
     are still accepted by pages that haven't been retagged yet — they
     simply won't highlight any nav item.
════════════════════════════════════════════════════════════════════ -->
<header class="nav" role="banner">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="cheetochopsticks home">
        <img src="/shared/cheetochopstickslogo.svg" alt="" class="nav-logo-img" width="437" height="42">
      </a>
      <nav class="nav-links" id="nav-links" aria-label="Site sections">
        <a class="nav-link{% if activeNav == 'orgchart' %} active{% endif %}" href="/microsites/shared/government-org-chart.html">Org Chart</a>
        <a class="nav-link{% if activeNav == 'local' %} active{% endif %}" href="/local/">Local</a>
        <a class="nav-link{% if activeNav == 'state' %} active{% endif %}" href="/state/">State</a>
        <a class="nav-link{% if activeNav == 'national' %} active{% endif %}" href="/national/">National</a>
      </nav>
      <div class="nav-right">
        <button
          type="button"
          class="nav-search-toggle"
          id="nav-search-toggle"
          aria-expanded="false"
          aria-controls="nav-search-panel"
          aria-label="Open site search">
          <svg class="nav-search-toggle__icon" aria-hidden="true" viewBox="0 0 20 20" focusable="false">
            <circle cx="9" cy="9" r="6" fill="none" stroke="currentColor" stroke-width="2"/>
            <line x1="13.5" y1="13.5" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="nav-search-toggle__label">Search</span>
        </button>
        <a class="subscribe-btn" href="/preferences/" aria-label="Subscribe to email updates">
          <span>Subscribe</span>
        </a>
        <button class="notif-btn" onclick="window.openNotif && window.openNotif()" aria-label="Open alerts and notifications, 11 unread" aria-haspopup="dialog" aria-expanded="false" aria-controls="notif-panel">
          <span>Alerts</span>
          <span class="notif-count" aria-live="polite">11</span>
        </button>
      </div>

      <!-- ─── Nav search dropdown (disclosure pattern) ────────────────
           Toggled by #nav-search-toggle. Lazy-fetches /search-index.json
           on first open, then runs the same client-side filtering as
           the homepage block. role="region" + aria-label gives screen
           readers a recognizable landmark; hidden attribute is the
           authoritative open/close state. -->
      <div
        id="nav-search-panel"
        class="nav-search-panel"
        role="region"
        aria-label="Site search"
        hidden>
        <div class="nav-search-panel__inner">
          <div class="nav-search-panel__chips" role="group" aria-label="Filter results by jurisdiction tier">
            <button type="button" class="nav-search-panel__chip" data-tier="all"      aria-pressed="true">All</button>
            <button type="button" class="nav-search-panel__chip" data-tier="local"    aria-pressed="false">Local</button>
            <button type="button" class="nav-search-panel__chip" data-tier="state"    aria-pressed="false">State</button>
            <button type="button" class="nav-search-panel__chip" data-tier="national" aria-pressed="false">National</button>
          </div>
          <form class="nav-search-panel__form" id="nav-search-form" role="search" aria-label="Site search">
            <label class="sr-only" for="nav-search-input">Search topics, agencies, records, or address</label>
            <input
              type="search"
              id="nav-search-input"
              class="nav-search-panel__input"
              name="q"
              autocomplete="off"
              spellcheck="false"
              placeholder="Search anything — or type a ZIP / address"
              aria-describedby="nav-search-status">
            <button type="submit" class="nav-search-panel__submit">
              <span class="sr-only">Run search</span>
              <span aria-hidden="true">→</span>
            </button>
            <button type="button" class="nav-search-panel__close" id="nav-search-close" aria-label="Close search">
              <span aria-hidden="true">✕</span>
            </button>
          </form>
          <p class="nav-search-panel__status" id="nav-search-status" role="status" aria-live="polite"></p>
          <ul class="nav-search-panel__results" id="nav-search-results" role="list"></ul>
          <p class="nav-search-panel__empty" id="nav-search-empty" hidden>No matches in this tier. Try a different filter or a shorter query.</p>
        </div>
      </div>

<style>
  /* Subscribe button in the dark nav. Gold border + gold label on dark bg.
     Contrast: cc-gold (#c8a84b) on cc-bg (#0c1220) = 8.2:1 (AAA). */
  .subscribe-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 1px solid var(--cc-gold);
    border-radius: 4px;
    padding: 7px 14px;
    margin-right: 8px;
    color: var(--cc-gold);
    font-family: var(--cc-mono);
    font-size: .75rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .18s, color .18s;
    min-height: 32px;
  }
  .subscribe-btn:hover,
  .subscribe-btn:focus-visible {
    background: var(--cc-gold);
    color: #0c1220;
  }
  @media (max-width: 600px) {
    .subscribe-btn { padding: 7px 10px; }
    .subscribe-btn span { display: none; }
    .subscribe-btn::before {
      content: "✉";
      font-size: 1rem;
      line-height: 1;
    }
  }
</style>
    </div>
  </div>
</header>
