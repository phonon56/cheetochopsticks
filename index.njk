<!-- ═══ UNIVERSAL SEARCH & DISCOVERY ═════════════════════════════════
     One input handles three jobs:
       • address or ZIP → routes to the jurisdiction finder
       • topic / subject ("housing", "metro district", "ada") → results
       • agency name ("CSPD", "BOCC", "DOLA")              → results
     Filter chips above the input scope the search to a tier.
     Search index is generated at build time in _data/searchIndex.js
     and inlined below so client-side filtering is instant.            -->
<section class="search-discovery" aria-labelledby="search-discovery-h">
  <div class="container">
    <h2 id="search-discovery-h" class="search-discovery__heading">Search the site</h2>
    <p class="search-discovery__deck">Type a topic, an agency, a record, or an address. Filter by jurisdiction tier. Address lookups route to the finder.</p>

    <div class="search-discovery__chips" role="group" aria-label="Filter results by jurisdiction tier">
      <button type="button" class="search-discovery__chip" data-tier="all"      aria-pressed="true">All</button>
      <button type="button" class="search-discovery__chip" data-tier="local"    aria-pressed="false">Local</button>
      <button type="button" class="search-discovery__chip" data-tier="state"    aria-pressed="false">State</button>
      <button type="button" class="search-discovery__chip" data-tier="national" aria-pressed="false">National</button>
    </div>

    <form class="search-discovery__form" id="search-discovery-form" role="search" aria-label="Site search">
      <label class="sr-only" for="search-discovery-input">Search topics, agencies, records, or address</label>
      <input
        type="search"
        id="search-discovery-input"
        class="search-discovery__input"
        name="q"
        autocomplete="off"
        spellcheck="false"
        placeholder="Try &quot;housing&quot;, &quot;CSPD&quot;, &quot;metro district audit&quot;, or 80903"
        aria-describedby="search-discovery-hint">
      <button type="submit" class="search-discovery__btn">Search&nbsp;→</button>
    </form>
    <p class="search-discovery__hint" id="search-discovery-hint">Filtering happens as you type. Press Enter to deep-link the search.</p>

    <div class="search-discovery__results" id="search-discovery-results" role="region" aria-live="polite" aria-label="Search results" hidden>
      <p class="search-discovery__count" id="search-discovery-count"></p>
      <ul class="search-discovery__list" id="search-discovery-list" role="list"></ul>
      <p class="search-discovery__empty" id="search-discovery-empty" hidden>No matches in this tier. Try a different filter or a shorter query.</p>
    </div>
  </div>

  <script id="search-discovery-index" type="application/json">{{ searchIndex | dump | safe }}</script>
</section>

