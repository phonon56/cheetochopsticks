{# Page-specific fonts and CSS — kept inline (HTML5 allows <style> in body) #}
{# so we avoid extracting and serving from a separate file for now.        #}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400;1,700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Color palette — verified WCAG 2.1 AA / AAA on --bg #0c1220
         Contrast ratios (minimum text 4.5:1 AA, 7:1 AAA):
           text    #ede8dc → 15.3  AAA
           muted   #96adc4 →  8.1  AAA
           quiet   #8ca3b8 →  7.2  AAA  (was #506070, 2.9 — FAIL)
           gold    #c8a84b →  8.2  AAA
           gold-lt #fde68a → 15.0  AAA
           red     #fca5a5 →  9.9  AAA  (was #f87171, 6.8 AA)
           green   #4ade80 → 10.7  AAA
           blue    #60a5fa →  7.4  AAA
           amber   #fbbf24 → 11.2  AAA                                  */
      --bg:         #0c1220;
      --surface:    #141e2e;
      --surface2:   #1c2a3e;
      --surface3:   #233045;
      --border:     rgba(255,255,255,.14);
      --border-hi:  rgba(255,255,255,.28);
      --gold:       #c8a84b;
      --gold-dim:   rgba(200,168,75,.22);
      --gold-faint: rgba(200,168,75,.09);
      --gold-lt:    #fde68a;
      --text:       #ede8dc;
      --muted:      #96adc4;
      --quiet:      #8ca3b8;
      --mono:       'IBM Plex Mono', monospace;
      --sans:       'IBM Plex Sans', sans-serif;
      --serif:      'Playfair Display', Georgia, serif;
      --red:        #fca5a5;
      --red-dim:    rgba(252,165,165,.16);
      --green:      #4ade80;
      --green-dim:  rgba(74,222,128,.14);
      --blue:       #60a5fa;
      --blue-dim:   rgba(96,165,250,.14);
      --amber:      #fbbf24;
      --amber-dim:  rgba(251,191,36,.16);
    }

    html { scroll-behavior: smooth; }

    /* ── Skip link (ADA) ────────────────────────────────────── */
    .skip-link {
      position: absolute;
      top: -100px;
      left: 16px;
      background: var(--gold);
      color: #0c1220;
      font-family: var(--mono);
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .08em;
      padding: 10px 18px;
      border-radius: 3px;
      text-decoration: none;
      z-index: 9999;
      transition: top .2s;
    }
    .skip-link:focus { top: 16px; }

    /* ── Focus visible — universal gold ring ─────────────────────── */
    *:focus { outline: none; }
    *:focus-visible {
      outline: 3px solid var(--gold);
      outline-offset: 3px;
      border-radius: 2px;
    }

    /* ── Serif subheadline ───────────────────────────────────────── */
    .section-sub {
      font-family: var(--sans);
      font-style: normal;
      font-weight: 400;
      font-size: 1.05rem;
      color: var(--muted);
      line-height: 1.6;
      margin-top: 4px;
      margin-bottom: 28px;
      max-width: 560px;
    }

    @media (prefers-reduced-motion: reduce) {
      .ticker-track { animation: none; }
      * { transition-duration: 0.01ms !important; }
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 18px;
      line-height: 1.7;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    .container { max-width: 900px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

    /* ── NAV ─────────────────────────────────────────────────────── */
    .nav {
      border-bottom: 1px solid var(--border);
      padding: 14px 0;
      position: sticky;
      top: 0;
      background: rgba(10,15,26,.94);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      z-index: 200;
    }
    .nav-inner {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .nav-logo {
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 1px;
      margin-right: 32px;
      flex-shrink: 0;
    }
    .nav-logo-img {
      height: 42px;
      width: auto;
      display: block;
    }
    .nav-logo:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 4px;
      border-radius: 2px;
    }
    /* Legacy text-logo styles kept for any other surfaces that reference them */
    .nav-logo-word {
      font-family: var(--sans);
      font-weight: 600;
      font-size: .95rem;
      letter-spacing: -.01em;
      color: var(--text);
    }
    .nav-logo-dot { color: var(--gold); font-size: .95rem; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
      flex: 1;
    }
    .nav-link {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 3px;
      border: 1px solid transparent;
      transition: all .18s;
      white-space: nowrap;
    }
    .nav-link:hover { color: var(--text); background: rgba(255,255,255,.04); }
    .nav-link.you-link {
      color: var(--gold);
      border-color: var(--gold-dim);
      background: var(--gold-faint);
    }
    .nav-link.you-link:hover { background: var(--gold-dim); }
    .nav-link.active {
      color: var(--text);
      border-color: var(--border-hi);
      background: rgba(255,255,255,.06);
      text-decoration: underline;
      text-decoration-color: var(--gold);
      text-underline-offset: 3px;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-left: auto;
      flex-shrink: 0;
    }
    .notif-btn {
      position: relative;
      background: none;
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 6px 10px;
      cursor: pointer;
      color: var(--muted);
      font-size: .78rem;
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--mono);
      letter-spacing: .06em;
      transition: all .18s;
    }
    .notif-btn:hover { color: var(--text); border-color: var(--border-hi); }
    .notif-count {
      background: var(--red);
      color: #0a0f1a;
      font-size: .78rem;
      font-weight: 700;
      border-radius: 10px;
      padding: 1px 5px;
      font-family: var(--mono);
      line-height: 1.4;
    }

    /* ── NOTIFICATIONS PANEL ─────────────────────────────────────── */
    .notif-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.4);
      z-index: 300;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s;
    }
    .notif-overlay.open { opacity: 1; pointer-events: all; }
    .notif-panel {
      position: fixed;
      top: 0; right: 0; bottom: 0;
      width: 360px;
      background: var(--surface);
      border-left: 1px solid var(--border-hi);
      z-index: 301;
      transform: translateX(100%);
      transition: transform .28s cubic-bezier(.32,.72,0,1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .notif-panel.open { transform: translateX(0); }
    .notif-panel-head {
      padding: 20px 20px 14px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .notif-panel-title {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--text);
    }
    .notif-close {
      background: none;
      border: 1px solid var(--border);
      border-radius: 3px;
      color: var(--muted);
      font-size: .78rem;
      padding: 4px 10px;
      cursor: pointer;
      font-family: var(--mono);
      transition: all .15s;
    }
    .notif-close:hover { color: var(--text); border-color: var(--border-hi); }
    .notif-filters {
      display: flex;
      gap: 6px;
      padding: 12px 20px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      flex-wrap: wrap;
    }
    .nf-btn {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 4px 10px;
      border: 1px solid var(--border);
      border-radius: 2px;
      background: none;
      color: var(--muted);
      cursor: pointer;
      transition: all .15s;
    }
    .nf-btn:hover { color: var(--text); border-color: var(--border-hi); }
    .nf-btn.active { background: var(--gold-dim); color: var(--gold); border-color: rgba(200,168,75,.3); }
    .notif-scroll { flex: 1; overflow-y: auto; padding: 8px 0; }
    .notif-group-label {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--quiet);
      padding: 10px 20px 4px;
    }
    .notif-item {
      padding: 12px 20px;
      display: flex;
      gap: 12px;
      align-items: flex-start;
      border-bottom: 1px solid var(--border);
      transition: background .15s;
      cursor: default;
    }
    .notif-item:hover { background: rgba(255,255,255,.02); }
    .notif-item.hidden { display: none; }
    .notif-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 5px;
    }
    .nd-red    { background: var(--red); }
    .nd-amber  { background: var(--amber); }
    .nd-blue   { background: var(--blue); }
    .nd-green  { background: var(--green); }
    .nd-gold   { background: var(--gold); }
    .nd-quiet  { background: var(--quiet); }
    .notif-body { flex: 1; }
    .notif-text {
      font-size: .85rem;
      color: var(--text);
      line-height: 1.55;
      margin-bottom: 3px;
    }
    .notif-text strong { color: var(--gold-lt); font-weight: 500; }
    .notif-meta {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .08em;
      color: var(--quiet);
      margin-bottom: 4px;
    }
    .notif-action {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid var(--gold-dim);
      padding-bottom: 1px;
      transition: border-color .15s;
    }
    .notif-action:hover { border-color: var(--gold); }

    /* ── TICKER ──────────────────────────────────────────────────── */
    .ticker-wrap {
      overflow: hidden;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 10px 0;
      position: relative;
    }
    .ticker-wrap::before,
    .ticker-wrap::after {
      content: '';
      position: absolute;
      top: 0; bottom: 0;
      width: 80px;
      z-index: 2;
    }
    .ticker-wrap::before { left: 0;  background: linear-gradient(90deg, var(--bg), transparent); }
    .ticker-wrap::after  { right: 0; background: linear-gradient(-90deg, var(--bg), transparent); }
    .ticker-track {
      display: flex;
      gap: 0;
      animation: ticker 36s linear infinite;
      width: max-content;
    }
    .ticker-track:hover { animation-play-state: paused; }
    @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    .ticker-item {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 0 28px;
      white-space: nowrap;
    }
    .ticker-item strong { color: var(--text); }
    .ticker-item.alert { color: var(--red); }
    .ticker-sep { width: 1px; background: var(--border-hi); flex-shrink: 0; align-self: stretch; margin: 2px 0; }

    /* ── SECTIONS ────────────────────────────────────────────────── */
    .section { padding: 56px 0; border-bottom: 1px solid var(--border); }
    .section-anchor { position: relative; top: -80px; }
    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 28px;
      gap: 16px;
      flex-wrap: wrap;
    }
    .section-eyebrow {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .section-eyebrow::before {
      content: '';
      display: inline-block;
      width: 20px; height: 1px;
      background: var(--gold);
      opacity: .5;
    }
    .section-header h2 {
      font-family: var(--serif);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
    }
    .section-note {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ── HERO ────────────────────────────────────────────────────── */
    .hero {
      padding: 72px 0 56px;
      border-bottom: 1px solid var(--border);
    }
    .eyebrow {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .eyebrow::before {
      content: '';
      display: inline-block;
      width: 28px; height: 1px;
      background: var(--gold);
      opacity: .5;
    }
    .hero h1 {
      font-family: var(--serif);
      font-size: clamp(2.2rem, 5.5vw, 3.6rem);
      font-weight: 700;
      line-height: 1.12;
      letter-spacing: -.02em;
      color: var(--text);
      margin-bottom: 22px;
    }
    .hero h1 em { font-style: normal; color: var(--gold); }
    .hero-sub {
      max-width: 560px;
      font-size: 1.05rem;
      color: var(--muted);
      line-height: 1.75;
      margin-bottom: 32px;
    }
    .hero-sub strong { color: var(--text); font-weight: 500; }

    /* ── YOU SECTION ─────────────────────────────────────────────── */
    .you-banner {
      background: var(--gold-faint);
      border: 1px solid var(--gold-dim);
      border-radius: 6px;
      padding: 28px 32px;
      margin-bottom: 32px;
      position: relative;
      overflow: hidden;
    }
    .you-banner::after {
      content: 'YOU';
      position: absolute;
      right: 24px; top: 50%;
      transform: translateY(-50%);
      font-family: var(--serif);
      font-size: 7rem;
      font-weight: 900;
      font-style: normal;
      color: rgba(200,168,75,.06);
      pointer-events: none;
      line-height: 1;
      user-select: none;
    }
    .you-banner h3 {
      font-family: var(--serif);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 8px;
    }
    .you-banner p {
      font-size: .95rem;
      color: var(--muted);
      line-height: 1.7;
      max-width: 500px;
      margin-bottom: 18px;
    }
    .you-banner p strong { color: var(--text); font-weight: 500; }
    .you-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--gold);
      color: #0a0f1a;
      font-family: var(--mono);
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      padding: 10px 20px;
      border-radius: 3px;
      text-decoration: none;
      transition: background .18s;
    }
    .you-cta:hover { background: var(--gold-lt); }
    .you-stat-row {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 10px;
      margin-top: 20px;
    }
    .you-stat {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 14px 16px;
    }
    .you-stat-label {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--quiet);
      margin-bottom: 6px;
    }
    .you-stat-val {
      font-family: var(--serif);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
    }
    .you-stat-val.red { color: var(--red); }
    .you-stat-val.amber { color: var(--amber); }
    .you-stat-val.gold { color: var(--gold); }
    .you-stat-sub {
      font-size: .78rem;
      color: var(--muted);
      margin-top: 4px;
    }

    /* ── PAGE CARDS ──────────────────────────────────────────────── */
    .page-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
    }
    .page-card {
      background: var(--surface);
      padding: 22px 26px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: start;
      text-decoration: none;
      transition: background .18s;
      position: relative;
    }
    .page-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--gold);
      opacity: 0;
      transition: opacity .18s;
    }
    .page-card:hover { background: var(--surface2); }
    .page-card:hover::before { opacity: 1; }
    .page-card:hover .card-title { color: var(--gold); }
    .card-left { min-width: 0; }
    .card-scope {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 5px;
    }
    .card-title {
      font-family: var(--sans);
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      transition: color .18s;
      margin-bottom: 5px;
      line-height: 1.3;
    }
    .card-desc {
      font-size: .88rem;
      color: var(--muted);
      line-height: 1.6;
    }
    .card-desc em { font-style: normal; color: var(--muted); }
    .card-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
      padding-top: 2px;
      white-space: nowrap;
    }
    .card-arrow {
      font-size: .85rem;
      color: var(--muted);
      transition: color .18s, transform .18s;
    }
    .page-card:hover .card-arrow { color: var(--gold); transform: translate(2px,-1px); }

    /* ── GROUP CARDS (multi-link) ────────────────────────────────── */
    .group-card {
      background: var(--surface);
      padding: 22px 26px 6px;
      position: relative;
      border-left: 3px solid transparent;
      transition: border-color .18s, background .18s;
    }
    .group-card:hover { border-left-color: var(--gold); background: var(--surface2); }
    .group-card .card-left { padding-bottom: 10px; }
    .group-links {
      border-top: 1px solid var(--border);
      margin-top: 6px;
      display: flex;
      flex-direction: column;
    }
    .group-link {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 12px 2px;
      text-decoration: none;
      border-bottom: 1px solid var(--border);
      transition: padding-left .18s;
    }
    .group-link:last-child { border-bottom: none; }
    .group-link:hover { padding-left: 8px; }
    .group-link:hover .group-link-title { color: var(--gold); }
    .group-link:hover .group-link-arrow { color: var(--gold); transform: translate(2px,-1px); }
    .group-link-title {
      font-family: var(--sans);
      font-size: .92rem;
      font-weight: 500;
      color: var(--text);
      line-height: 1.35;
      transition: color .18s;
    }
    .group-link-sub {
      display: block;
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .08em;
      color: var(--quiet);
      text-transform: uppercase;
      margin-top: 3px;
    }
    .group-link-arrow {
      font-size: .85rem;
      color: var(--muted);
      transition: color .18s, transform .18s;
    }

    /* ── SCOPE HEADINGS within Dashboards section ────────────────── */
    .scope-heading {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--gold);
      margin: 40px 0 14px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .scope-heading:first-of-type { margin-top: 6px; }
    .scope-heading::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── TAPE BADGES ─────────────────────────────────────────────── */
    .tape {
      display: inline-block;
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 3px 9px;
      border-radius: 2px;
      vertical-align: middle;
    }
    .tape-live    { background: rgba(74,222,128,.12); color: #4ade80; border: 1px solid rgba(74,222,128,.25); }
    .tape-wip     { background: rgba(251,191,36,.12); color: #fbbf24; border: 1px solid rgba(251,191,36,.25); }
    .tape-soon    { background: rgba(96,165,250,.1);  color: #60a5fa; border: 1px solid rgba(96,165,250,.2); }
    .tape-critical{ background: var(--red-dim);        color: var(--red); border: 1px solid rgba(248,113,113,.25); }
    .tape-shared  { background: var(--gold-faint);    color: var(--gold); border: 1px solid var(--gold-dim); }

    /* ── MINI CARDS (2-col grid) ─────────────────────────────────── */
    .mini-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 10px;
      margin-top: 4px;
    }
    .mini-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 5px;
      padding: 16px 18px;
      text-decoration: none;
      display: block;
      transition: all .18s;
      position: relative;
    }
    .mini-card:hover { background: var(--surface2); border-color: var(--border-hi); }
    .mini-card:hover .mini-title { color: var(--gold); }
    .mini-tag {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .mini-title {
      font-family: var(--sans);
      font-size: .95rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 5px;
      line-height: 1.3;
      transition: color .18s;
    }
    .mini-desc { font-size: .83rem; color: var(--muted); line-height: 1.55; }
    .mini-footer {
      margin-top: 10px;
      padding-top: 8px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .mini-stat {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .08em;
      color: var(--quiet);
    }
    .mini-stat strong { color: var(--muted); }

    /* ── PEOPLE ──────────────────────────────────────────────────── */
    .people-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
    }
    .person-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 5px;
      padding: 14px 16px;
      display: flex;
      align-items: flex-start;
      gap: 10px;
      transition: border-color .18s;
    }
    .person-card:hover { border-color: var(--border-hi); }
    .person-avatar {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--gold-dim);
      border: 1px solid rgba(200,168,75,.3);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--mono);
      font-size: .78rem;
      font-weight: 700;
      color: var(--gold);
      flex-shrink: 0;
      letter-spacing: .04em;
    }
    .person-name {
      font-size: .95rem;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 4px;
      line-height: 1.3;
    }
    .person-role {
      font-size: .82rem;
      color: var(--muted);
      line-height: 1.5;
    }
    .person-tag {
      display: inline-block;
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      background: var(--gold-faint);
      color: var(--gold);
      border: 1px solid var(--gold-dim);
      padding: 2px 6px;
      border-radius: 2px;
      margin-top: 5px;
    }

    /* ── EVENTS ──────────────────────────────────────────────────── */
    .events-list { display: flex; flex-direction: column; gap: 8px; }
    .event-row {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 5px;
      padding: 14px 16px;
      display: flex;
      align-items: flex-start;
      gap: 16px;
      transition: border-color .18s;
    }
    .event-row:hover { border-color: var(--border-hi); }
    .event-date { text-align: center; flex-shrink: 0; width: 38px; }
    .event-month {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .event-day {
      font-family: var(--sans);
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
    }
    .event-body { flex: 1; }
    .event-title {
      font-size: .88rem;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 3px;
    }
    .event-detail { font-size: .83rem; color: var(--muted); line-height: 1.6; }
    .event-badge {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 2px;
      flex-shrink: 0;
      margin-left: auto;
      align-self: flex-start;
      white-space: nowrap;
    }
    .eb-critical { background: var(--red-dim); color: var(--red); border: 1px solid rgba(248,113,113,.2); }
    .eb-warn { background: var(--amber-dim); color: var(--amber); border: 1px solid rgba(251,191,36,.2); }
    .eb-info { background: var(--blue-dim); color: var(--blue); border: 1px solid rgba(96,165,250,.2); }
    .eb-ok   { background: var(--green-dim); color: var(--green); border: 1px solid rgba(74,222,128,.2); }

    /* ── COMING SOON ─────────────────────────────────────────────── */
    .coming-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px;
      margin-top: 4px;
    }
    .coming-card {
      background: var(--surface);
      border: 1px dashed rgba(255,255,255,.08);
      border-radius: 4px;
      padding: 16px 18px;
    }
    .coming-card p {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .08em;
      color: var(--muted);
      line-height: 1.6;
    }
    .coming-card p strong { color: var(--text); font-weight: 600; }

    /* ── DISPATCH ────────────────────────────────────────────────── */
    .dispatch { padding: 48px 0; }
    .dispatch-box {
      background: var(--gold-faint);
      border: 1px solid var(--gold-dim);
      border-radius: 6px;
      padding: 32px 36px;
    }
    .dispatch-box h3 {
      font-family: var(--sans);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 10px;
    }
    .dispatch-box p { color: var(--muted); font-size: .95rem; line-height: 1.7; max-width: 540px; }
    .dispatch-box p + p { margin-top: 10px; }
    .dispatch-box strong { color: var(--text); font-weight: 500; }

    /* ── FOOTER ──────────────────────────────────────────────────── */
    .footer {
      border-top: 1px solid var(--border);
      padding: 32px 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .footer p {
      font-family: var(--mono);
      font-size: .8rem;
      letter-spacing: .09em;
      color: var(--muted);
    }
    .footer a { color: var(--muted); text-decoration: none; }
    .footer a:hover { color: var(--gold); }

    /* ── DIVIDERS ────────────────────────────────────────────────── */
    .section-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 32px 0 24px;
    }
    .section-divider-line { flex: 1; height: 1px; background: var(--border); }
    .section-divider-label {
      font-family: var(--mono);
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--quiet);
      white-space: nowrap;
    }

    @media (max-width: 600px) {
      .hero { padding: 48px 0 40px; }
      .page-card { grid-template-columns: 1fr; }
      .card-right { flex-direction: row; align-items: center; }
      .dispatch-box { padding: 24px 20px; }
      .you-banner { padding: 22px 20px; }
      .you-banner::after { display: none; }
      .notif-panel { width: 100%; }
      .nav-links { display: none; }
      .nav-links.mobile-open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0; right: 0;
        background: rgba(12,18,32,.98);
        border-bottom: 1px solid var(--border-hi);
        padding: 12px 16px;
        gap: 4px;
        z-index: 199;
      }
      .nav-menu-btn { display: flex; }
    }
    @media (min-width: 601px) {
      .nav-menu-btn { display: none; }
    }
    .nav-menu-btn {
      background: none;
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--muted);
      font-size: .78rem;
      padding: 6px 10px;
      cursor: pointer;
      font-family: var(--mono);
      transition: all .15s;
      margin-left: 8px;
    }
    .nav-menu-btn:hover { color: var(--text); border-color: var(--border-hi); }

    /* ─── Tier organization — Local / State / National ────────────────────
       Three-tier grouping for the dashboards section. Each tier has an
       intro band, an h3 heading, the existing scope sub-sections nested
       inside (their h3 → h4 demotion preserves heading hierarchy under
       the section's h2), and a "How this connects" callout between tiers.

       Naming convention (block__element--modifier):
         .tier                              outermost wrapper
         .tier--local / --state / --national   per-tier modifier
         .tier__band                        colored intro band
         .tier__eyebrow / __heading / __intro   band contents
         .connection-callout                between-tier callout
         .connection-callout__label / __body
         .start-here                        local-tier hero block
         .start-here__finder / __initiatives / __tile
         .tier-nav                          sticky in-page tier nav
         .tier-nav__list / __label / __link
         .tier-nav__link--current           active link modifier
       Edit one of these classes to change the look across all tiers.   */

    .tier { margin: 56px 0; }
    .tier:first-of-type { margin-top: 24px; }
    .tier__band {
      border-left: 4px solid var(--gold);
      padding: 22px 26px 20px;
      margin-bottom: 26px;
      border-radius: 0 4px 4px 0;
    }
    .tier--local    .tier__band { background: rgba(200,168,75,.07); }
    .tier--state    .tier__band { background: rgba(96,165,250,.07);  border-left-color: var(--blue); }
    .tier--national .tier__band { background: rgba(74,222,128,.07);  border-left-color: var(--green); }
    .tier__eyebrow {
      font-family: var(--mono);
      font-size: .74rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .tier__heading {
      font-family: var(--serif);
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 10px;
    }
    .tier__intro {
      font-size: .95rem;
      line-height: 1.6;
      color: var(--muted);
      max-width: 720px;
    }
    .tier__intro strong { color: var(--text); }

    /* Between-tier "how these connect" callout */
    .connection-callout {
      margin: 30px 0 6px;
      padding: 16px 20px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      font-size: .9rem;
      line-height: 1.6;
      color: var(--muted);
    }
    .connection-callout__label {
      font-family: var(--mono);
      font-size: .72rem;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 6px;
    }
    .connection-callout__body strong { color: var(--text); }
    .connection-callout__body a {
      color: var(--gold-lt);
      text-decoration: none;
      border-bottom: 1px solid rgba(253,230,138,.4);
    }
    .connection-callout__body a:hover { color: var(--text); border-bottom-color: var(--text); }
    .connection-callout__body a:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 3px;
      color: var(--text);
    }

    /* "Start here" block at the top of Local */
    .start-here {
      margin: 0 0 30px;
      padding: 22px 24px 22px;
      background: var(--surface2);
      border: 1px solid var(--border-hi);
      border-radius: 5px;
    }
    .start-here__eyebrow {
      font-family: var(--mono);
      font-size: .72rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 6px;
    }
    .start-here__title {
      font-family: var(--serif);
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 14px;
    }
    .start-here__finder {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 6px;
    }
    .start-here__finder-label {
      width: 100%;
      font-family: var(--mono);
      font-size: .74rem;
      color: var(--muted);
      letter-spacing: .04em;
      margin-bottom: 4px;
    }
    .start-here__input {
      flex: 1 1 240px;
      background: var(--bg);
      color: var(--text);
      border: 1px solid var(--border-hi);
      border-radius: 4px;
      padding: 11px 14px;
      font-family: var(--sans);
      font-size: .94rem;
    }
    .start-here__input::placeholder { color: var(--quiet); }
    .start-here__input:focus-visible {
      outline: 3px solid var(--gold);
      outline-offset: 1px;
      border-color: var(--gold);
    }
    .start-here__btn {
      background: var(--gold);
      color: var(--bg);
      border: 1px solid var(--gold);
      border-radius: 4px;
      padding: 11px 22px;
      font-family: var(--mono);
      font-size: .82rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      font-weight: 600;
      cursor: pointer;
    }
    .start-here__btn:hover { background: var(--gold-lt); border-color: var(--gold-lt); }
    .start-here__btn:focus-visible {
      outline: 3px solid var(--gold-lt);
      outline-offset: 3px;
    }
    .start-here__hint {
      width: 100%;
      font-size: .82rem;
      color: var(--quiet);
      line-height: 1.5;
      margin: 4px 0 18px;
    }
    .start-here__rail-label {
      font-family: var(--mono);
      font-size: .74rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 4px 0 12px;
    }
    .start-here__initiatives {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
    }
    .start-here__tile {
      display: block;
      padding: 14px 16px 14px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text);
      text-decoration: none;
      transition: border-color .15s;
    }
    .start-here__tile:hover { border-color: var(--gold); }
    .start-here__tile:focus-visible {
      outline: 3px solid var(--gold);
      outline-offset: 2px;
    }
    .start-here__tile-scope {
      font-family: var(--mono);
      font-size: .7rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 6px;
    }
    .start-here__tile-title {
      font-weight: 600;
      font-size: .94rem;
      line-height: 1.35;
      color: var(--text);
    }
    .start-here__tile-meta {
      font-size: .8rem;
      color: var(--muted);
      margin-top: 6px;
    }

    /* Sticky in-page tier nav */
    .tier-nav {
      position: sticky;
      top: 0;
      z-index: 30;
      background: rgba(12,18,32,.92);
      -webkit-backdrop-filter: blur(8px);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      padding: 10px 0;
      margin: 0 0 18px;
    }
    .tier-nav__list {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
      align-items: center;
      list-style: none;
      margin: 0 auto;
      padding: 0 24px;
      max-width: 1200px;
    }
    .tier-nav__label {
      font-family: var(--mono);
      font-size: .72rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--quiet);
      margin-right: 10px;
    }
    .tier-nav__link {
      display: inline-block;
      font-family: var(--mono);
      font-size: .8rem;
      letter-spacing: .08em;
      color: var(--muted);
      text-decoration: none;
      padding: 7px 14px;
      border: 1px solid transparent;
      border-radius: 999px;
      transition: color .15s, border-color .15s, background .15s;
    }
    .tier-nav__link:hover { color: var(--text); border-color: var(--border-hi); }
    .tier-nav__link:focus-visible {
      outline: 3px solid var(--gold);
      outline-offset: 2px;
    }
    .tier-nav__link--current,
    .tier-nav__link[aria-current="location"] {
      color: var(--bg);
      background: var(--gold);
      border-color: var(--gold);
    }

    @media (max-width: 640px) {
      .tier-nav__list {
        flex-wrap: nowrap;
        overflow-x: auto;
        scrollbar-width: thin;
        padding: 0 16px;
      }
      .tier-nav__label,
      .tier-nav__link { flex-shrink: 0; }
      .tier__band { padding: 18px 18px 16px; }
      .tier__heading { font-size: 1.35rem; }
      .start-here { padding: 18px 18px 20px; }
      .start-here__btn { width: 100%; }
    }

    @media (prefers-reduced-motion: reduce) {
      .start-here__tile,
      .tier-nav__link { transition: none; }
      html { scroll-behavior: auto !important; }
    }
  </style>


