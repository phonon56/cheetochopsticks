<!-- ─── Tier-nav active-state observer ────────────────────────────────
     Watches the three tier sections (#tier-local / #tier-state /
     #tier-national) and toggles aria-current="location" on the matching
     .tier-nav__link as the user scrolls through them. Falls back to no
     active state if IntersectionObserver is unavailable. -->
<script>
(function(){
  if(!('IntersectionObserver' in window)) return;

  /* Gather every link that points to a tier anchor — covers both the
     in-page sticky tier-nav (.tier-nav__link[data-tier-link]) and the
     top nav (.nav-link href="/#tier-X"). Group by target id so we can
     toggle all matching links together as the observer fires. */
  var ids = ['tier-local','tier-state','tier-national'];
  var linksById = {};
  ids.forEach(function(id){ linksById[id] = []; });

  document.querySelectorAll('.tier-nav__link[data-tier-link]').forEach(function(a){
    var id = a.dataset.tierLink;
    if(linksById[id]) linksById[id].push(a);
  });
  document.querySelectorAll('.nav-link[href]').forEach(function(a){
    var href = a.getAttribute('href') || '';
    var m = href.match(/#(tier-(?:local|state|national))$/);
    if(m && linksById[m[1]]) linksById[m[1]].push(a);
  });

  var observed = ids.map(function(id){ return document.getElementById(id); }).filter(Boolean);
  if(!observed.length) return;

  function setCurrent(id){
    ids.forEach(function(k){
      linksById[k].forEach(function(link){
        if(k === id){
          link.setAttribute('aria-current', 'location');
          link.classList.add('tier-nav__link--current');
          if(link.classList.contains('nav-link')) link.classList.add('active');
        } else {
          link.removeAttribute('aria-current');
          link.classList.remove('tier-nav__link--current');
          if(link.classList.contains('nav-link')) link.classList.remove('active');
        }
      });
    });
  }

  var observer = new IntersectionObserver(function(entries){
    /* Pick the most-visible section among entries that are intersecting. */
    var best = null;
    entries.forEach(function(e){
      if(e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) best = e;
    });
    if(best) setCurrent(best.target.id);
  }, { rootMargin: '-30% 0px -55% 0px', threshold: [0, 0.1, 0.3, 0.6] });

  observed.forEach(function(el){ observer.observe(el); });
})();
</script>

