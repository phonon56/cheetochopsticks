.chip{font-family:var(--sans);font-size:13px;padding:6px 12px;border:1.5px solid var(--rule);
  background:var(--off);color:var(--muted);border-radius:100px;cursor:pointer;
  transition:all .15s;font-weight:500;}
.chip:hover{border-color:var(--muted);color:var(--ink);background:var(--white);}
.chip[aria-pressed="true"]{background:var(--navy);border-color:var(--navy);color:#fff;}
.chip-count{font-family:var(--mono);font-size:13px;color:var(--muted);margin-left:5px;}
