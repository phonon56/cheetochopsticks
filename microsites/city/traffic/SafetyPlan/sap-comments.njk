<style>
/* ===== DESIGN TOKENS ===== — palette inherited from cos-traffic-hub.
   Verified WCAG 2.1 AA/AAA on card backgrounds (--off #f8fafc, --white).
   ink #0f172a → 17.06 AAA · navy #001a4d → 15.99 AAA · muted #3d5166 → 7.82 AAA
   blue #0049b1 → 7.76 AAA · green #065f46 → 7.34 AAA
   red #991b1b → 6.18 AA · amber-ink #92400e → 6.78 AA · gold-ink #735504 → 6.62 AA
   gold #c8a84b kept for borders only — NOT text-safe (2.19 FAIL). */
:root {
  --navy:#001a4d; --blue:#0049b1; --sky:#1d6fa4; --teal:#0b7a75;
  --red:#991b1b; --amber:#d97706; --gold:#c8a84b; --green:#065f46;
