  padding:8px 16px;border-radius:3px;font-family:var(--mono);font-size:13px;text-decoration:none;z-index:999;}
.skip:focus{left:8px;}
:focus-visible{outline:3px solid var(--gold);outline-offset:2px;border-radius:2px;
  box-shadow:0 0 0 5px rgba(0,0,0,0.55);}
.sr-only{position:absolute!important;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;
  clip:rect(0,0,0,0);white-space:nowrap;border:0;}

/* ===== HERO ===== — same gradient as cos-traffic-hub */
