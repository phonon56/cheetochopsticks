.filter-search input:hover,.filter-select select:hover{border-color:var(--muted);background:var(--white);}
.filter-search input:focus,.filter-select select:focus{border-color:var(--blue);background:var(--white);}

.filter-chips{margin-top:14px;display:flex;flex-wrap:wrap;gap:6px;align-items:center;}
.filter-chips-label{font-family:var(--mono);font-size:13px;letter-spacing:.08em;
