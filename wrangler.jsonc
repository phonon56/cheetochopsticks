{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cheetochopsticks",
  "compatibility_date": "2026-04-06",
  "main": "./worker/index.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
